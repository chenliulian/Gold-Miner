# GoldMiner 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# =============================================================================
# LLM API 配置 (OpenAI-compatible)
# =============================================================================
# 主用 LLM 配置 (最高优先级)
LLM_BASE_URL=https://your-llm-api-endpoint.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o
# LLM_TIMEOUT=30  # 可选，默认30秒

# 备用 LLM 配置 1 (当主用失败时自动切换)
# 支持多种命名方式：
# 方式1: 使用 LLM_*_backup1 前缀
# LLM_BASE_URL_backup1=https://backup1-llm-api.com/v1
# LLM_API_KEY_backup1=your-backup1-api-key
# LLM_MODEL_backup1=gpt-4o-mini
# LLM_TIMEOUT_backup1=30

# 方式2: 使用 OPENAI_* 前缀 (兼容旧配置)
# OPENAI_BASE_URL=https://backup1-llm-api.com/v1
# OPENAI_API_KEY=your-backup1-api-key
# OPENAI_MODEL=gpt-4o-mini

# 备用 LLM 配置 2 (当备用1也失败时切换)
# 支持多种命名方式：
# 方式1: 使用 LLM_*_backup2 前缀
# LLM_BASE_URL_backup2=https://backup2-llm-api.com/v1
# LLM_API_KEY_backup2=your-backup2-api-key
# LLM_MODEL_backup2=qwen-max
# LLM_TIMEOUT_backup2=30

# 方式2: 使用 DASHSCOPE_* 前缀 (兼容旧配置，阿里云DashScope)
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_KEY=your-dashscope-api-key
# DASHSCOPE_MODEL=qwen-max

# 故障转移说明：
# 1. 系统启动时自动检测所有配置的 LLM Provider
# 2. 优先级顺序: primary > backup1 > backup2
# 3. 当某个 Provider 连续失败 2 次后，自动切换到下一个
# 4. 新会话始终优先尝试 primary
# 5. 每个 Provider 独立追踪健康状态，失败 3 次标记为 DEGRADED，5 次标记为 UNHEALTHY

# =============================================================================
# Tavily Search API (用于搜索技能)
# =============================================================================
TAVILY_API_KEY=your-tavily-api-key

# =============================================================================
# MaxCompute / ODPS 配置
# =============================================================================
ODPS_ACCESS_ID=your-access-id
ODPS_ACCESS_KEY=your-access-key
ODPS_PROJECT=your-project-name
ODPS_ENDPOINT=http://service.eu-central-1.maxcompute.aliyun.com/api

# ODPS Quota 配置 (可选，用于指定调度资源)
# ODPS_QUOTA=your-quota-name

# =============================================================================
# Agent 配置
# =============================================================================
# 最大执行步数
AGENT_MAX_STEPS=20

# 记忆存储路径
MEMORY_PATH=./memory/memory.json

# 报告输出目录
REPORTS_DIR=./reports

# =============================================================================
# Feishu (飞书) 配置
# =============================================================================
# 飞书应用机器人 (用于消息通知)
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# 默认发送群 ID
FEISHU_DEFAULT_CHAT_ID=your-chat-id

# 飞书SSO登录配置 (用于用户认证)
# 飞书SSO回调地址，例如: http://localhost:5000/auth/feishu/callback
FEISHU_REDIRECT_URI=http://localhost:5000/auth/feishu/callback

# =============================================================================
# 用户认证配置
# =============================================================================
# JWT密钥 - 用于签名认证令牌，建议使用至少32字符的随机字符串
# 生成示例: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-min-32-chars-long

# Token过期时间(小时)
TOKEN_EXPIRES_HOURS=8

# =============================================================================
# Web UI 配置 (可选)
# =============================================================================
PORT=5000
FLASK_DEBUG=false

# =============================================================================
# 安全配置 (必须)
# =============================================================================
# 会话密钥 - 必须设置为至少32字符的随机字符串
# 生成示例: openssl rand -hex 32
SESSION_SECRET=your-secure-random-session-secret-min-32-chars-long

# =============================================================================
# Agent Pool 配置 (可选)
# =============================================================================
# Agent池最小数量
AGENT_POOL_MIN_SIZE=2
# Agent池最大数量
AGENT_POOL_MAX_SIZE=10
# Agent最大空闲时间(秒)
AGENT_POOL_MAX_IDLE_TIME=3600

# =============================================================================
# 限流配置 (可选)
# =============================================================================
# 默认限流: 每分钟请求数
RATE_LIMIT_DEFAULT_PER_MINUTE=60
# 聊天限流: 每分钟请求数
RATE_LIMIT_CHAT_PER_MINUTE=10

# =============================================================================
# 熔断器配置 (可选)
# =============================================================================
# 熔断器触发失败次数阈值
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# 熔断器恢复超时时间(秒)
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30
